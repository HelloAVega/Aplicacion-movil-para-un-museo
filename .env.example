# Configuración de entorno - Copiar a .env y personalizar

# Para el backend Django (desarrollo):
DJANGO_SECRET_KEY=dev-change-me
# DEBUG puede ser True en desarrollo, False en producción
DEBUG=True

# Base de datos (ejemplo): SQLite local usado por el proyecto Django
# Para producción use una URL de PostgreSQL: postgresql://usuario:contraseña@host:puerto/db
DATABASE_URL=sqlite:///backend/db.sqlite3

# Rutas y subida de archivos
MEDIA_ROOT=backend/media
MEDIA_URL=/media/
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760  # 10 MB en bytes

# CORS - ajustar en producción
CORS_ORIGINS=["http://127.0.0.1:8001", "http://localhost:3000"]

# Notas:
# - Este archivo es ejemplo. Django lee configuración desde settings.py; puede usar python-dotenv
#   o revisar variables en production deployment.
